# Streamlit secrets template.
#
# Local dev: copy this file to .streamlit/secrets.toml and fill in your key
#            (that file is gitignored). You can also just use a .env file instead.
# Deploy:    paste these values into the "Secrets" box in the Streamlit Community
#            Cloud app settings — do NOT commit the real secrets.toml.

GOOGLE_API_KEY = "your-api-key-here"

# Optional overrides (defaults shown):
# GEMINI_MODEL = "gemini-2.5-flash-lite"
# GEMINI_MAX_RETRIES = "6"
