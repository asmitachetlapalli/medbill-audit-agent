# Copy this file to .env and fill in your values. Do not commit .env.

# Required for the AI summary / audit agent (Google AI Studio API key).
GOOGLE_API_KEY=your-api-key-here

# Optional. Gemini model used by the agent. Defaults to gemini-2.5-flash-lite.
# Verified working: gemini-2.5-flash-lite, gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional. Retries on transient 429 rate limits (exponential backoff). Defaults to 6.
# GEMINI_MAX_RETRIES=6

# Optional. Password-gate the app. When unset, the app is open to anyone with the URL.
# APP_PASSWORD=choose-a-strong-password
